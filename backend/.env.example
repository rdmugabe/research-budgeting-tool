# Backend env vars. Copy to .env and customize for local use.
# DATABASE_URL examples:
#   SQLite (default for local):  sqlite:///./app.db
#   Postgres (cloud / docker):   postgresql+psycopg://rbt:rbt@localhost:5432/rbt
DATABASE_URL=sqlite:///./app.db

# JWT secret. CHANGE THIS for any non-local environment.
JWT_SECRET=dev-secret-change-me-before-cloud
